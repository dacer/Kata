<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="IconicsBtnStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">#757575</item>
    </style>
    <style name="ToolbarStyle" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="android:background">@color/toolbarBackground</item>
    </style>

    <style name="SettingsItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">62dp</item>
        <item name="android:layout_marginBottom">1dp</item>œ
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>
    <style name="SettingsItem.MoreTopDivider">
        <item name="android:layout_marginTop">16dp</item>
    </style>
    <style name="SettingsItem.WrapHeight">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>
    <style name="SettingsItemLeft">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="SettingsItemLeft.Title">
        <item name="android:textSize">16sp</item>
    </style>
    <style name="SettingsItemSummary">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#BDBDBD</item>
    </style>
    <style name="SettingsItemRight">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:layout_alignParentRight">true</item>
    </style>
    <style name="DiscreteSeekBar">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="dsb_progressColor">@color/colorPrimary</item>
        <item name="dsb_indicatorColor">@color/colorPrimary</item>
    </style>
    <style name="DiscreteSeekBar.TopMargin">
        <item name="android:layout_marginTop">10dp</item>
    </style>
</resources>