<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nothingHappenedView"
    android:layout_gravity="center"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/item_word_margin"
    android:layout_marginLeft="@dimen/item_word_margin"
    android:layout_marginRight="@dimen/item_word_margin"
    card_view:cardCornerRadius="4dp"
    android:layout_below="@+id/tutorialLayout">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/baseFormTv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:maxLines="5"
                android:ellipsize="end"/>
        </LinearLayout>

    </RelativeLayout>

</android.support.v7.widget.CardView>