<?xml version="1.0" encoding="utf-8"?>

<android.support.v7.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:apptool="http://schemas.android.com/tools"
    android:id="@+id/backgroundLayout"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardElevation="0dp"
    app:cardCornerRadius="@dimen/flashcard_radius">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">
        <TextView
            android:id="@+id/queryTimesTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textColor="#78ffffff"
            android:layout_alignParentRight="true"
            android:layout_alignParentTop="true"
            apptool:text="6"
            />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:id="@+id/baseFormTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textColor="@color/md_white_1000"
                apptool:text="еҪјеҘі"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/md_white_1000"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/contextTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/md_white_1000"
                apptool:text="гҒ“гӮҢгҒҜеҪјеҘігҒҢй…’зІҫгҒ«жөёгҒЈгҒҹеӨңгҒ®ж—…и·ҜгӮ’еЁҒйўЁе ӮгҖ…жӯ©гҒҚжҠңгҒ„гҒҹиЁҳйҢІгҒ§гҒӮгӮҠгҖҒгҒҫгҒҹгҖҒгҒӨгҒ„гҒ«..." />

        </LinearLayout>
    </RelativeLayout>
</android.support.v7.widget.CardView>